# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CDR_TOPIC=cdr.raw
KAFKA_KPI_TOPIC=network.kpi
KAFKA_BILLING_TOPIC=billing.events
KAFKA_IPDR_TOPIC=ipdr.raw

# GCP (fill in after Day 10)
GCP_PROJECT_ID=your-gcp-project-id
GCP_BUCKET_NAME=vi-telecom-data-lake
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
BQ_DATASET=vi_telecom

# Airflow
AIRFLOW_UID=50000

# Data generation
NUM_SUBSCRIBERS=50000
NUM_TOWERS=500
SIMULATION_DAYS=90
